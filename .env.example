# Telegram bot token (zorunlu) - @BotFather'dan alinir
TELEGRAM_BOT_TOKEN=your_telegram_token_here

# OpenAI API anahtari (opsiyonel) - yoksa bot kural-tabanli calisir
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

# Veritabani (varsayilan: yerel SQLite)
DATABASE_URL=sqlite:///bot.db

# Webhook ayarlari (uretim icin). Gelistirmede bos birak -> polling calisir.
USE_WEBHOOK=false
WEBHOOK_URL=
WEBHOOK_PORT=8443
